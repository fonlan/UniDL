{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UniDL",
  "version": "0.1.0",
  "identifier": "top.fonlan.unidl",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1450",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "UniDL",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 620,
        "center": true,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["magnet"]
      }
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "fileAssociations": [
      {
        "ext": ["torrent"],
        "name": "UniDL.Torrent",
        "description": "BitTorrent 文件",
        "mimeType": "application/x-bittorrent",
        "role": "Viewer"
      }
    ]
  }
}
