{
  "manifest_version": 3,
  "name": "UniDL",
  "version": "0.1.4",
  "description": "Send browser downloads to the local UniDL desktop service.",
  "permissions": ["contextMenus", "cookies", "downloads", "storage", "tabs"],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:18080/*",
    "http://localhost:18080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_title": "UniDL",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    },
    "default_popup": "popup.html"
  },
  "options_page": "settings.html"
}
